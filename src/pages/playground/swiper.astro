---
import Layout from "../../layouts/Layout.astro";
import {
  Swiper as SwiperWrapper,
  SwiperItem,
} from "../../components/swiper/index.ts";

const slides = [
  "Slide 1",
  "Slide 2",
  "Slide 3",
  "Slide 4",
  "Slide 5",
  "Slide 6",
  "Slide 7",
  "Slide 8",
  "Slide 9",
];
---

<Layout>
  <h1 class="text-4xl">Swiper</h1>
  <SwiperWrapper
    id="my-swiper"
    className="my-swiper"
    className="pb-12!"
    desktop={3}
    tablet={2}
    mobile={1}
    gap={20}
    options={{
      loop: true,
      centeredSlides: true,
      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
      },
      pagination: {
        el: "#my-swiper .swiper-pagination",
        clickable: true,
        dynamicBullets: true,
      },
    }}
  >
    {
      slides.map((slide) => (
        <SwiperItem className="border border-gray-200 p-10 rounded bg-gray-50">
          {slide}
        </SwiperItem>
      ))
    }
  </SwiperWrapper>

  <h2 class="text-3xl">Vertical</h2>

  <SwiperWrapper
    id="my-swiper-vertical"
    className="my-swiper-vertical h-[400px]! w-full divide-y-1 divide-gray-300"
    options={{
      direction: "vertical",
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
    }}
  >
    {
      slides.map((slide) => (
        <SwiperItem>
          <div class="bg-gray-100 p-10 h-full flex justify-center items-center text-xl">
            {slide}
          </div>
        </SwiperItem>
      ))
    }
  </SwiperWrapper>
</Layout>
